# Recall — environment configuration
# Copy this file to `.env` and fill in your keys. Restart the dev server after changes.
#
# All EXPO_PUBLIC_* vars are embedded in the JS bundle (they are NOT secret).
# See README.md for how to provision Supabase and where to put the OpenAI key.

# --- Supabase (auth + synced database) -------------------------------------
# Leave both BLANK to run the app fully offline against the local AsyncStorage
# store (great for design review). Fill them in to enable real auth + sync.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- AI: transcription (Whisper) + evaluation (GPT) ------------------------
# The PRD wants the evaluator decoupled and NOT Claude (GPT/Gemini). This app
# ships an OpenAI implementation (Whisper + GPT). Leave the key blank to fall
# back to a deterministic local evaluator/transcriber stub so the flow still runs.
#
# SECURITY: a key placed here is bundled into the client. Fine for a personal,
# single-user build. For anything shared, proxy these calls through a backend
# (e.g. a Supabase Edge Function) and point EXPO_PUBLIC_AI_PROXY_URL at it.
EXPO_PUBLIC_OPENAI_API_KEY=
EXPO_PUBLIC_OPENAI_EVAL_MODEL=gpt-4o-mini
EXPO_PUBLIC_OPENAI_TRANSCRIBE_MODEL=whisper-1

# Optional: route AI calls through your own backend instead of calling OpenAI
# directly from the device. When set, the app POSTs to `${URL}/transcribe` and
# `${URL}/evaluate` instead of api.openai.com.
EXPO_PUBLIC_AI_PROXY_URL=
